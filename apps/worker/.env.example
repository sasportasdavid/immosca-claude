# Secrets du worker Trigger.dev (jamais commit le .env réel).
#
# Pour le dev local : copier ce fichier en .env et remplir.
#   cp .env.example .env
#
# Pour Trigger.dev cloud (production) : ces mêmes valeurs sont à pousser
# via le dashboard https://cloud.trigger.dev/projects/<proj>/environments
# (onglet Environment Variables) — pas via ce fichier qui ne sert qu'au
# `trigger.dev dev` local.

# ──────────────── Trigger.dev ────────────────
# Le project ref est lu par trigger.config.ts. Format : "proj_xxx".
TRIGGER_PROJECT_ID=proj_xxx
# Clé API DEV (commence par "tr_dev_…"), pour `trigger.dev dev` local.
TRIGGER_SECRET_KEY=tr_dev_xxx

# ──────────────── Supabase immoscan-app ────────────────
# URL du projet (https://<ref>.supabase.co).
SUPABASE_APP_URL=https://vztzzysrainmznjnurbl.supabase.co
# Service role key (Settings → API → "service_role" — JAMAIS côté frontend).
SUPABASE_APP_SERVICE_ROLE_KEY=

# ──────────────── Supabase immoscan-data ────────────────
SUPABASE_DATA_URL=https://riihwfenotjdnwrimlet.supabase.co
SUPABASE_DATA_SERVICE_ROLE_KEY=

# ──────────────── Apify (scraping SeLoger + Leboncoin) ────────────────
# Token API (Console → Settings → Integrations → API token).
APIFY_TOKEN=
# IDs des actors publics utilisés. Format : "username~actor-name" ou ID.
# Si tu changes d'actor (ex. fork privé), modifie juste ces deux vars.
APIFY_ACTOR_SELOGER=
APIFY_ACTOR_LEBONCOIN=

# ──────────────── Anthropic (Claude) ────────────────
# Clé API (sk-ant-…). Le modèle est défini côté code (Sonnet 4.6 default,
# Opus 4.7 pour Business).
ANTHROPIC_API_KEY=

# ──────────────── Observabilité (optionnel) ────────────────
# Sentry DSN pour le worker (laisse vide si pas encore configuré).
SENTRY_DSN_WORKER=
