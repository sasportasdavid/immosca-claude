# ImmoValue — variables d'environnement frontend.
#
# Le projet partage l'AUTH avec ImmoScan (même Supabase project immoscan-app).
# Copier dans .env.local à la racine du repo (les deux apps lisent la même
# source, cf vite.config.ts → envDir).

# Supabase (immoscan-app — projet transactionnel)
VITE_SUPABASE_APP_URL=
VITE_SUPABASE_APP_ANON_KEY=

# URL publique de l'app (utilisée par les Edge Functions pour les redirects).
VITE_APP_URL=http://localhost:5174

# Observabilité (optionnelles — no-op si absentes)
VITE_SENTRY_DSN_WEB=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.posthog.com
