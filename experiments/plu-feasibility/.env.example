# Spike PLU — variables d'environnement
# Copier en .env (non commité)

# Anthropic — pour le test d'extraction de règlement
ANTHROPIC_API_KEY=sk-ant-...

# Modèle à utiliser pour le test (Opus 4.7 recommandé pour le raisonnement juridique)
ANTHROPIC_MODEL=claude-opus-4-7

# Concurrence du batch (combien d'adresses en parallèle pour le mesure de couverture)
BATCH_CONCURRENCY=5
